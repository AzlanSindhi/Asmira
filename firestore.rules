rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bookings — anyone can create, only admin reads (via Firebase Console or server SDK)
    match /bookings/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['firstName','lastName','email','phone','preferredDate','sessionType'])
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 200
        && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName.size() > 0;
      allow read, update, delete: if false;
    }

    // Contact messages — anyone can create, no public read
    match /messages/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['name','email','subject','message'])
        && request.resource.data.message.size() >= 20
        && request.resource.data.message.size() <= 5000
        && request.resource.data.email is string;
      allow read, update, delete: if false;
    }

    // Feedback — anyone can create, no public read
    match /feedback/{id} {
      allow create: if
        request.resource.data.keys().hasAll(['patientName','sessionType','rating','feedback'])
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.feedback.size() >= 20;
      allow read, update, delete: if false;
    }
  }
}
